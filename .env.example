# At least one LLM provider key is required by the backend. Never prefix these with NEXT_PUBLIC_.
GROQ_API_KEY=
# CEREBRAS_API_KEY=
# OPENROUTER_API_KEY=

# Optional: protects direct API consumers. Send this value as X-API-Key or
# Authorization: Bearer <token>. Leave blank for the bundled browser UI.
SEARCH_API_TOKEN=

# Comma-separated browser origins allowed to call the API. Use your deployed URL
# in production, e.g. https://your-project.vercel.app
ALLOWED_ORIGINS=*

# Optional only when the backend is intentionally hosted on another origin.
# NEXT_PUBLIC_API_URL=https://api.example.com
